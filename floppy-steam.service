[Unit]
Description=Floppy-disk Steam game launcher
# Only run once the graphical session is up, so `steam` has a display.
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 %h/Floppy-Steam-Loader/floppy_steam_daemon.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
